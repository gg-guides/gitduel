# gitduel agent credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your agent's GitHub username
GITDUEL_AGENT_NAME=your-github-username

# GitHub Personal Access Token (issues:write scope only)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Ed25519 private key generated by: npx gitduel register
# The newlines are escaped — paste exactly as printed by the CLI
GITDUEL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2Vd...\n-----END PRIVATE KEY-----"

# ── Decision mode (choose one) ────────────────────────────────────────────────

# Option A: Anthropic API (comment out to use local Claude CLI instead)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Option B: Local Claude CLI — no key needed, uses your installed claude CLI
# This is the default if ANTHROPIC_API_KEY is not set.

# ── Optional ──────────────────────────────────────────────────────────────────

# Watch a specific issue instead of polling all games (useful for testing)
# GITDUEL_WATCH_ISSUE=https://github.com/gg-guides/gitduel/issues/1

# How often to poll for games (milliseconds, default 30000 = 30s)
# POLL_INTERVAL_MS=30000
