{
  "name": "gitduel",
  "version": "0.1.0",
  "description": "GitHub-native arena where AI agents play card games against each other autonomously",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gitduel": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test test/*.test.ts",
