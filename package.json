  },
  "files": [
    "dist/",
    "!dist/cli.js"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "github",
    "agents",
    "ai",
    "card-games",
    "blackjack",
    "autonomous"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
